// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  logo_url      String?
  primary_color String   @default("#1a1a1a")
  domain        String?
  email         String?
  phone         String?
  address       String?
  whatsapp      String?
  instagram_url String?
  facebook_url  String?
  tiktok_url    String?
  pinterest_url           String?
  instagram_access_token  String?
  instagram_token_expiry  DateTime?
  instagram_user_id       String?
  active                  Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  users        User[]
  panels       Panel[]
  accessories  Accessory[]
  inquiries    Inquiry[]
  leads        Lead[]
  projects     Project[]
  galleryItems GalleryItem[]
  blogPosts    BlogPost[]
  designers    Designer[]
  dealers      Dealer[]
  partners     Partner[]
  teamMembers  TeamMember[]
  heroSlides   HeroSlide[]
  pageContents PageContent[]
  collections  Collection[]

  @@map("tenants")
}

model User {
  id            String   @id @default(cuid())
  tenant_id     String
  email         String
  password_hash String
  role          Role     @default(ADMIN)
  created_at    DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, email])
  @@map("users")
}

enum Role {
  ADMIN
  VIEWER
}

model PanelCategory {
  id         String @id @default(cuid())
  tenant_id  String
  name       String
  sort_order Int    @default(0)

  panels Panel[]

  @@map("panel_categories")
}

model Panel {
  id              String   @id @default(cuid())
  tenant_id       String
  category_id     String?
  name            String
  zip_url         String?
  width_mm        Int      @default(500)
  height_mm       Int      @default(500)
  depth_mm        Int      @default(19)
  weight_kg       Float?
  price           Float?
  description     String?
  material        String?
  depth_relief_mm Int?
  active          Boolean  @default(true)
  sort_order      Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant      Tenant         @relation(fields: [tenant_id], references: [id])
  category    PanelCategory? @relation(fields: [category_id], references: [id])
  sizes       PanelSize[]
  panelImages PanelImage[]

  @@map("panels")
}

model PanelImage {
  id         String  @id @default(cuid())
  panel_id   String
  url        String
  caption    String?
  sort_order Int     @default(0)

  panel Panel @relation(fields: [panel_id], references: [id], onDelete: Cascade)

  @@index([panel_id])
  @@map("panel_images")
}

model PanelSize {
  id         String  @id @default(cuid())
  panel_id   String
  label      String
  width_mm   Float
  height_mm  Float
  depth_mm   Float
  price      Float?
  sort_order Int     @default(0)

  panel Panel @relation(fields: [panel_id], references: [id], onDelete: Cascade)

  @@map("panel_sizes")
}

model Collection {
  id          String   @id @default(cuid())
  tenant_id   String
  name        String
  slug        String
  description String?
  cover_url   String?
  panel_ids   Json     @default("[]")
  active      Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, slug])
  @@index([tenant_id])
  @@map("collections")
}

model AccessoryType {
  id       String @id @default(cuid())
  name     String @unique
  label_ru String
  icon_url String?

  accessories Accessory[]

  @@map("accessory_types")
}

model Accessory {
  id         String  @id @default(cuid())
  tenant_id  String
  type_id    String
  name       String
  sku        String?
  model_url  String
  thumb_url  String
  scale      Float   @default(1.0)
  price      Float?
  active     Boolean @default(true)
  sort_order Int     @default(0)

  tenant Tenant        @relation(fields: [tenant_id], references: [id])
  type   AccessoryType @relation(fields: [type_id], references: [id])

  @@map("accessories")
}

model Inquiry {
  id           String   @id @default(cuid())
  tenant_id    String
  name         String
  phone        String
  email        String?
  message      String?
  wall_width   Float?
  wall_height  Float?
  panel_names  String?
  created_at   DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("inquiries")
}

model Lead {
  id          String   @id @default(cuid())
  tenant_id   String
  name        String
  phone       String
  comment     String?
  wall_config Json
  screenshot  String?
  status      String   @default("new")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@index([status])
  @@map("leads")
}

// ── CONTENT MODELS ────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  tenant_id   String
  title       String
  slug        String
  description String?
  cover_url   String?
  images      Json     @default("[]")
  space_type  String?
  panel_ids   Json     @default("[]")
  active      Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, slug])
  @@index([tenant_id])
  @@map("projects")
}

model GalleryItem {
  id         String   @id @default(cuid())
  tenant_id  String
  image_url  String
  thumb_url  String?
  caption    String?
  space_type String?
  tags       Json     @default("[]")
  sort_order Int      @default(0)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("gallery_items")
}

model BlogPost {
  id           String    @id @default(cuid())
  tenant_id    String
  slug         String
  title        Json
  excerpt      Json
  body         Json
  cover_url    String?
  category     String?
  tags         Json      @default("[]")
  published    Boolean   @default(false)
  published_at DateTime?
  sort_order   Int       @default(0)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, slug])
  @@index([tenant_id])
  @@index([published])
  @@map("blog_posts")
}

model Designer {
  id         String   @id @default(cuid())
  tenant_id  String
  name       String
  slug       String
  photo_url  String?
  bio        Json?
  specialty  String?
  portfolio  Json     @default("[]")
  instagram  String?
  website    String?
  active     Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, slug])
  @@index([tenant_id])
  @@map("designers")
}

model Dealer {
  id         String   @id @default(cuid())
  tenant_id  String
  name       String
  country    String
  region     String?
  city       String
  address    String?
  phone      String?
  email      String?
  website    String?
  map_url    String?
  lat        Float?
  lng        Float?
  logo_url   String?
  active     Boolean  @default(true)
  sort_order Int      @default(0)

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@index([country])
  @@map("dealers")
}

model Partner {
  id         String   @id @default(cuid())
  tenant_id  String
  name       String
  logo_url   String
  website    String?
  sort_order Int      @default(0)
  active     Boolean  @default(true)

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("partners")
}

model TeamMember {
  id         String   @id @default(cuid())
  tenant_id  String
  name       String
  role       Json
  photo_url  String?
  bio        Json?
  sort_order Int      @default(0)
  active     Boolean  @default(true)

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("team_members")
}

model HeroSlide {
  id          String   @id @default(cuid())
  tenant_id   String
  image_url   String
  video_url   String?
  headline    Json
  subheadline Json?
  cta_label   Json?
  cta_url     String?
  sort_order  Int      @default(0)
  active      Boolean  @default(true)

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("hero_slides")
}

model PageContent {
  id         String   @id @default(cuid())
  tenant_id  String
  page_key   String
  content    Json
  updated_at DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, page_key])
  @@index([tenant_id])
  @@map("page_contents")
}
