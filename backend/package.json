{
  "name": "wallcraft-backend",
  "version": "1.0.0",
  "description": "WallCraft Visualizer API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && ts-node prisma/seed.ts",
    "seed:demo": "ts-node src/scripts/reset-and-seed.ts",
    "migrate:thumbs": "ts-node src/scripts/migrate-thumbs-to-images.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@prisma/client": "^5.8.0",
    "@types/cookie-parser": "^1.4.10",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.1.0",
    "nodemon": "^3.0.3",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
