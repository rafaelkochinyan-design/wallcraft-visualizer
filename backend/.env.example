# Copy to .env and fill in values

DATABASE_URL=postgresql://postgres:password@localhost:5432/wallcraft

JWT_SECRET=change_me_64_random_chars_hex_aaaa1111bbbb2222cccc3333dddd4444
JWT_REFRESH_SECRET=change_me_different_64_chars_eeee5555ffff6666gggg7777hhhh8888

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=wallcraft-assets
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
